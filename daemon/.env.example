YANDEX_CLIENT_ID=your_client_id_here
YANDEX_CLIENT_SECRET=your_client_secret_here
YANDEX_REDIRECT_URI=http://localhost:8000/callback

# Необязательно: абсолютный путь к SQLite (иначе ~/.local/share/cloudfusion/cloudfusion.db)
# DB_PATH=/home/you/.local/share/cloudfusion/cloudfusion.db

# Необязательно: CORS для WebView Tauri / dev (см. daemon/main.py)
# ALLOWED_ORIGINS=
# CORS_ORIGIN_REGEX=