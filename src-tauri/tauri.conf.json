{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "CloudFusion",
  "version": "0.1.0",
  "identifier": "com.cloudfusion.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
"windows": [
  {
    "title": "CloudFusion",
    "width": 420,
    "height": 650,
    "resizable": true,
    "decorations": true,
    "transparent": false
  }
],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
